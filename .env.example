# ═══════════════════════════════════════════════════════════
# SKILLTOK FRONTEND — VARIABLES FOR RAILWAY (Frontend Service)
# All vars MUST start with VITE_ to be exposed to the browser
# Add in Railway → Frontend Service → Variables → Raw Editor
# ═══════════════════════════════════════════════════════════

# ─── REQUIRED — Backend API endpoint ───────────────────
VITE_BACKEND_URL=https://skilltok-backend-production.up.railway.app

# ─── PAYMENT GATEWAY PUBLIC KEYS ────────────────────────
# Get from Paystack: https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx

# Get from Flutterwave: https://dashboard.flutterwave.com/settings/apis
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxx

# ─── PUSH NOTIFICATIONS VAPID Public Key ────────────────
# Generate matching key with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxx

# ─── LIVE STREAMING (Agora App ID for client SDK) ───────
VITE_AGORA_APP_ID=xxxxxxxxxxxxxxxx

# ─── DEFAULT CURRENCY ───────────────────────────────────
VITE_DEFAULT_CURRENCY=NGN

# ─── REFERRAL REWARD DISPLAY ────────────────────────────
VITE_REFERRAL_REWARD=₦500
