# ═══════════════════════════════════════════════════════════════
#  SkillTok Backend — Environment Variables
#  Copy this to .env for local dev, or paste into Railway Variables
# ═══════════════════════════════════════════════════════════════

# ── Core (REQUIRED) ──────────────────────────────────────────
NODE_ENV=production
PORT=8080
DATABASE_URL=postgresql://user:password@host:5432/skilltok
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=another-long-random-string-different-from-above
CORS_ORIGIN=https://your-frontend.railway.app
FRONTEND_URL=https://your-frontend.railway.app
ADMIN_REGISTRATION_SECRET=your-admin-secret-key

# ── Email — pick ONE provider ─────────────────────────────────
# Option A: Resend (recommended — free 3k/month) → resend.com
RESEND_API_KEY=re_xxxx
EMAIL_FROM=SkillTok <noreply@yourdomain.com>

# Option B: SendGrid → sendgrid.com (free 100/day)
SENDGRID_API_KEY=SG.xxxx

# Option C: Mailgun → mailgun.com (free 5k/month for 3 months)
MAILGUN_API_KEY=key-xxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_REGION=us

# Option D: Brevo (formerly Sendinblue) → brevo.com (free 300/day)
BREVO_API_KEY=xkeysib-xxxx

# Option E: Gmail / any SMTP (simplest for testing)
EMAIL_SERVICE=gmail
EMAIL_USER=yourapp@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ── SMS / OTP — pick ONE provider ────────────────────────────
# Option A: Termii (Nigerian, recommended) → termii.com
TERMII_API_KEY=TLxxxx
TERMII_SENDER_ID=SkillTok

# Option B: Twilio → twilio.com (global, free $15 trial)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_PHONE=+1234567890

# Option C: Africa's Talking → africastalking.com (Nigerian/African)
AFRICASTALKING_API_KEY=xxxx
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=SkillTok
AT_API_KEY=xxxx
AT_USERNAME=sandbox
AT_SENDER_ID=SkillTok

# Option D: Vonage (formerly Nexmo) → vonage.com
VONAGE_API_KEY=xxxx
VONAGE_API_SECRET=xxxx
VONAGE_FROM=SkillTok

# Option E: Laaffic (Nigerian) → laaffic.com
LAAFFIC_API_KEY=xxxx
LAAFFIC_API_SECRET=xxxx
LAAFFIC_APP_ID=xxxx
LAAFFIC_SENDER_ID=SkillTok

# ── Payments — pick ONE provider ─────────────────────────────
# Option A: Paystack (Nigerian, recommended) → paystack.com
PAYSTACK_SECRET_KEY=sk_live_xxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_WEBHOOK_SECRET=xxxx
FLUTTERWAVE_WEBHOOK_HASH=xxxx

# Option B: Flutterwave → flutterwave.com
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxx

# Option C: Stripe → stripe.com (global)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Option D: Monnify → monnify.com (Nigerian)
MONNIFY_API_KEY=MK_xxxx
MONNIFY_SECRET_KEY=xxxx
MONNIFY_CONTRACT_CODE=xxxx

# ── File Storage — pick ONE provider ─────────────────────────
# Option A: Cloudinary (recommended — free 25GB) → cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# Option B: AWS S3 → aws.amazon.com/s3
AWS_ACCESS_KEY_ID=AKIAxxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# Option C: Backblaze B2 (cheapest) → backblaze.com/b2 ($6/TB)
B2_KEY_ID=xxxx
B2_APPLICATION_KEY=xxxx
B2_BUCKET_ID=xxxx
B2_BUCKET_NAME=your-bucket-name

# Option D: Uploadcare → uploadcare.com (free 3GB)
UPLOADCARE_PUBLIC_KEY=xxxx

# ── Push Notifications — pick ONE ────────────────────────────
# Option A: Web Push VAPID (built-in, recommended — FREE)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BExxx...
VAPID_PRIVATE_KEY=xxx...
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Option B: Firebase FCM → firebase.google.com (free)
FIREBASE_SERVER_KEY=AAAAxxxx

# Option C: OneSignal → onesignal.com (free up to 10k subs)
ONESIGNAL_APP_ID=xxxx
ONESIGNAL_API_KEY=xxxx

# ── Currency Exchange (OPTIONAL — app works without it) ──────
# ExchangeRate-API free tier → exchangerate-api.com (1500 req/month free)
EXCHANGE_RATE_API_KEY=xxxx

# ── Misc (optional) ──────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379
REFERRAL_REWARD_NGN=500
LOYALTY_POINTS_SIGNUP=50
LOYALTY_POINTS_FIRST_ORDER=100
OPENAI_API_KEY=sk-xxxx

# ── AI / Grok ─────────────────────────────────────────────────
# xAI Grok API → console.x.ai (get your key at https://console.x.ai)
XAI_API_KEY=xai-xxxx

# ── OAuth (Social Login) ──────────────────────────────────────
# Google → console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://your-backend.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# GitHub → github.com/settings/applications/new
# Callback URL: https://your-backend.railway.app/api/auth/github/callback
GITHUB_CLIENT_ID=xxxx
GITHUB_CLIENT_SECRET=xxxx

# LinkedIn → linkedin.com/developers → Create App → Auth
# Redirect URL: https://your-backend.railway.app/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=xxxx
LINKEDIN_CLIENT_SECRET=xxxx
